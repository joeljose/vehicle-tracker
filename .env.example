# Docker container user — set to match your host UID/GID
# so bind-mounted files are owned by you, not root.
# The Makefile sets these automatically; only override if needed.
DS_UID=1000
DS_GID=1000

# GPU visibility (default: all GPUs)
NVIDIA_VISIBLE_DEVICES=all

# Pipeline backend: "custom" (default, ~6 GB) or "deepstream" (37.8 GB)
# Usage: make dev BACKEND_TYPE=custom
#        make dev BACKEND_TYPE=deepstream
# BACKEND_TYPE=custom
